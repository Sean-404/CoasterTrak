{
  "name": "coastertrak",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "wikidata:fetch": "tsx scripts/fetch-wikidata-coasters.ts --enrich --enrich-limit 200",
    "wikidata:reenrich": "tsx scripts/fetch-wikidata-coasters.ts --from-json --enrich --enrich-limit 1000",
    "wikidata:merge": "tsx scripts/merge-wikidata-coasters.ts",
    "wikidata:upload": "tsx --env-file=.env.local scripts/upload-wikidata-to-db.ts",
    "wikidata:upload-storage": "tsx --env-file=.env.local scripts/upload-wikidata-to-storage.ts",
    "wikipedia:backfill": "tsx --env-file=.env.local scripts/wikipedia-infobox-backfill.ts",
    "status:normalize": "tsx scripts/normalize-coaster-statuses.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "cheerio": "^1.2.0",
    "leaflet": "^1.9.4",
    "next": "^16.2.2",
    "papaparse": "^5.5.3",
    "react": "^19.2.5",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^6"
  }
}
